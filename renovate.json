{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "extends": [
    ":dependencyDashboard",
    ":ignoreUnstable",
    ":prImmediately",
    ":semanticPrefixFixDepsChoreOthers",
    ":updateNotScheduled",
    ":automergeDisabled",
    "helpers:disableTypesNodeMajor",
    "docker:enableMajor"
  ],
  "labels": ["dependencies"],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "packageRules": [
    {
      "description": "One PR for all non-major updates across every manager",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major dependencies",
      "automerge": false
    },
    {
      "description": "One PR for all major updates across every manager",
      "matchUpdateTypes": ["major"],
      "groupName": "all major dependencies",
      "automerge": false
    },
    {
      "description": "Skip major bump of kmsg to v2 - not usable until kgo/kadm depend on kmsg v2",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["github.com/twmb/franz-go/pkg/kmsg"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  }
}
